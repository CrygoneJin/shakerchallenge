# Copy to .env and fill in your values

# ── KSB Guard API ─────────────────────────────────────────────────────────────
# Your KSB Guard API key (request at ksbguard-support@ksb.com)
KSB_API_KEY=

# Target pump ID — leave empty to auto-detect the first assigned pump
KSB_PUMP_ID=

# Set to true to use the built-in simulator (no real sensor needed)
SENSOR_MOCK=true

# ── Game settings ─────────────────────────────────────────────────────────────
# Set EVENT_DAYS to the length of your event. The server automatically calculates
# the safest poll interval to stay within KSB Guard's 1,600 calls/month limit
# (assumes 50 sessions/day × 2 min avg active polling).
#
#   EVENT_DAYS=1  →  poll every  4 s  (~200 calls/day)
#   EVENT_DAYS=2  →  poll every  8 s  (~200 calls/day over 2 days)
#   EVENT_DAYS=5  →  poll every 19 s  (~200 calls/day over 5 days)
#
EVENT_DAYS=1

# Override the calculated poll interval if you need a specific value (ms).
# Leave blank to let EVENT_DAYS drive it.
POLL_INTERVAL_MS=

# How long to wait for a measurement before timing out (ms, default 180000 = 3 min)
WAIT_TIMEOUT_MS=180000

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
