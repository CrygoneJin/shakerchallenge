# Copy to .env and adjust values

# KSB Guard sensor REST endpoint (e.g. http://ksb-guard.local/api/measurements/latest)
# Leave empty or set SENSOR_MOCK=true to use the built-in simulator
SENSOR_URL=

# Set to true to force simulation mode even if SENSOR_URL is set
SENSOR_MOCK=true

# Challenge duration in milliseconds (default: 10000 = 10 s)
GAME_DURATION_MS=10000

# Server port
PORT=3001
