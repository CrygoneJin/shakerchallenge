# Copy to .env and fill in your values

# ── KSB Guard API ─────────────────────────────────────────────────────────────
# Your KSB Guard API key (request at ksbguard-support@ksb.com)
KSB_API_KEY=

# Target pump ID — leave empty to auto-detect the first assigned pump
KSB_PUMP_ID=

# Set to true to use the built-in simulator (no real sensor needed)
SENSOR_MOCK=true

# ── Game settings ─────────────────────────────────────────────────────────────
# How often to poll /measurements/last for a new timestamp (ms, default 5000)
# KSB Guard rate limit is 1,600 calls/sensor/month.
# At 30 s polling and 50 sessions/day × 2 min avg = ~200 calls/day → safe for a 5-day event.
POLL_INTERVAL_MS=30000

# How long to wait for a measurement before timing out (ms, default 180000 = 3 min)
WAIT_TIMEOUT_MS=180000

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
